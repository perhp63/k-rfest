---
interface Props {
  currentPath?: string
}
const { currentPath = "/" } = Astro.props

const links = [
  { href: "/#festen",   label: "Festen" },
  { href: "/#platsen",  label: "Platsen" },
  { href: "/anmalan",   label: "Anmälan" },
]
---

<nav class="navbar">
  <a href="/" class="nav-logo">Körfest 2026</a>
  <ul class="nav-links">
    {links.map(link => (
      <li><a href={link.href}>{link.label}</a></li>
    ))}
  </ul>
</nav>

<style>
.navbar {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20px 40px;
  background: linear-gradient(to bottom, rgba(13,21,32,0.9) 0%, transparent 100%);
}

.nav-logo {
  font-size: 18px;
  font-weight: 700;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: var(--color-gold);
}

.nav-links {
  list-style: none;
  display: flex;
  gap: 32px;
}

.nav-links a {
  font-size: 13px;
  font-weight: 500;
  letter-spacing: 0.05em;
  text-transform: uppercase;
  color: var(--color-text-muted);
  transition: color 0.2s;
}

.nav-links a:hover {
  color: var(--color-gold);
}

@media (max-width: 600px) {
  .navbar {
    padding: 16px 20px;
  }
  .nav-links {
    gap: 20px;
  }
}
</style>
